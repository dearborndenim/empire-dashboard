# GitHub API token for activity tracking (optional but recommended to avoid rate limits)
GITHUB_TOKEN=

# GitHub organization/owner for projects
GITHUB_OWNER=dearborndenim

# HTTP port
PORT=3000

# Health check cache TTL in seconds (default 60)
HEALTH_CACHE_TTL=60

# Health check HTTP timeout in ms (default 5000)
HEALTH_TIMEOUT_MS=5000

# Polling interval in ms (default 300000 = 5 min)
POLL_INTERVAL_MS=300000

# Optional: JSON file path overriding default app list
APPS_CONFIG_PATH=

# Optional: override per-app URLs (JSON map), e.g. {"McSecretary":"https://mcsecretary.up.railway.app"}
APPS_URL_OVERRIDES=

# Optional: per-app Railway logs deep link (JSON map), e.g.
# {"McSecretary":"https://railway.com/project/<project-id>/service/<service-id>?environmentId=<env>"}
APPS_RAILWAY_LOGS_OVERRIDES=

# Path to SQLite file storing 7-day health history (default ./data/history.db)
HISTORY_DB_PATH=./data/history.db

# How many days of history to retain (default 7)
HISTORY_RETENTION_DAYS=7

# Incident retention window in days (default 30) — closed incidents older
# than this are pruned once a day at 3 AM local; still-open incidents are
# always kept.
INCIDENTS_RETENTION_DAYS=30

# Shared secret for POST /api/incidents/:id/note. Send as x-admin-token header
# or "Authorization: Bearer <token>". Leave blank to disable the endpoint.
INCIDENTS_ADMIN_TOKEN=

# Weekly report email destination + sender
WEEKLY_REPORT_TO=rob@dearborndenim.com
WEEKLY_REPORT_FROM=

# Email transport: when SMTP_HOST is set (and EMAIL_DISABLED != 1) nodemailer
# delivers real SMTP; otherwise messages are logged to stdout.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_DISABLED=

# Integration observability tiles — PO receiver + kanban inbound webhook
# stats. Leave blank to render "Not configured" tiles.
PO_RECEIVER_URL=
PO_RECEIVER_API_KEY=
KANBAN_URL=
KANBAN_API_KEY=
